# All patterns use a leading / to anchor them to the repo root,
# preventing accidental matches inside server/node_modules/**

# Development source files (compiled output is in server/)
/src/
/dist/
/tsconfig.json
/jest.config.js

# Test files
/tests/

# Scripts / dev tools
/scripts/

# API reference documentation
/docs/

# Planning and project instructions
/PLAN.md
/CLAUDE.md

# CI/CD
/.github/

# Local Claude Code settings
/.claude/

# Root-level npm lock file only (package.json is needed by server/index.js at runtime)
/package-lock.json

# Root node_modules (deps are bundled in server/node_modules)
/node_modules/
